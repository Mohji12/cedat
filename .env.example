# Copy to `.env` in the repo root or `app/.env` for local runs.
# For AWS Lambda, set the same variables in the function configuration.

# Cloudinary (banner images + private CSV/Excel archives)
# Get these from Cloudinary Dashboard → API Keys
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Or set separately instead of CLOUDINARY_URL:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

SMTP_SERVER=smtp.zeptomail.in
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SENDER_EMAIL=
SENDER_NAME=
